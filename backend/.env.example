# Server
PORT=8080
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Redis
REDIS_URL=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Translation - Gemini
# Provide either GEMINI_API_KEY (from Google AI Studio) OR GOOGLE_APPLICATION_CREDENTIALS (path to GCP Service Account JSON)
GEMINI_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=e:\real-time-voice-translation\gen-lang-client-0204914626-a1ca27cc4b2c.json
GEMINI_MODEL=gemini-2.5-flash

# Default engine: "mymemory" (no key needed) or "gemini"
DEFAULT_ENGINE=gemini

# Cache
CACHE_TTL=1h

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# App
APP_VERSION=1.0.0
